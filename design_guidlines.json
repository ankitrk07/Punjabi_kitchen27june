{
  "brand": "Punjabi Kitchen",
  "theme": "Dark",
  "archetype": "5 (Jewel & Luxury)",
  "color_palette": {
    "background": "#0A0A0A",
    "surface": "#141414",
    "surface_glass": "rgba(10, 10, 10, 0.75)",
    "primary": "#D4AF37",
    "primary_hover": "#F3C846",
    "accent": "#E58B22",
    "text_primary": "#FFFFFF",
    "text_secondary": "#A3A3A3",
    "text_inverse": "#000000",
    "border": "#262626",
    "border_gold": "rgba(212, 175, 55, 0.3)",
    "error": "#EF4444",
    "success": "#10B981"
  },
  "typography": {
    "headings": {
      "font_family": "Cormorant Garamond, serif",
      "weights": ["400", "600", "700"],
      "letter_spacing": "tracking-tight"
    },
    "body": {
      "font_family": "Outfit, sans-serif",
      "weights": ["300", "400", "500"],
      "letter_spacing": "tracking-normal"
    },
    "sizes": {
      "h1": "text-4xl sm:text-5xl",
      "h2": "text-2xl sm:text-3xl",
      "h3": "text-xl sm:text-2xl",
      "body": "text-base",
      "small": "text-sm",
      "tiny": "text-xs uppercase tracking-[0.2em]"
    }
  },
  "spacing_and_layout": {
    "container": "w-full max-w-md mx-auto min-h-screen bg-[#0A0A0A] text-white overflow-x-hidden relative shadow-2xl",
    "padding": {
      "page": "px-4 py-6",
      "section": "py-8",
      "card": "p-4"
    },
    "radii": {
      "card": "rounded-2xl",
      "button": "rounded-full",
      "image": "rounded-xl"
    },
    "surfaces": {
      "glass_header": "bg-black/70 backdrop-blur-xl border-b border-white/10",
      "glass_bottom_nav": "bg-black/80 backdrop-blur-xl border-t border-white/10",
      "card_flat": "bg-[#141414] border border-white/5",
      "card_gold_trim": "bg-[#141414] border border-[#D4AF37]/30 shadow-[0_0_15px_rgba(212,175,55,0.05)]"
    }
  },
  "components": {
    "buttons": {
      "primary": "bg-[#D4AF37] text-black font-semibold rounded-full px-6 py-3 hover:bg-[#F3C846] transition-all active:scale-95",
      "secondary": "bg-transparent border border-[#D4AF37] text-[#D4AF37] rounded-full px-6 py-3 hover:bg-[#D4AF37]/10 transition-all",
      "ghost": "text-white/80 hover:text-[#D4AF37] transition-colors"
    },
    "header": {
      "layout": "flex justify-between items-center sticky top-0 z-50 h-16 px-4"
    },
    "bottom_nav": {
      "layout": "flex justify-around items-center fixed bottom-0 w-full max-w-md h-16 z-50 pb-safe"
    },
    "drawer": {
      "layout": "fixed inset-y-0 left-0 w-3/4 max-w-sm bg-[#141414] border-r border-white/10 z-[60] transform transition-transform"
    },
    "carousel": {
      "chef_special": "flex overflow-x-auto gap-4 scrollbar-hide snap-x snap-mandatory py-2",
      "reviews": "flex overflow-x-auto gap-4 scrollbar-hide py-2"
    }
  },
  "motion_and_animations": {
    "add_to_cart": {
      "description": "Dish image shrinks, floats up and right towards the cart icon, fading out.",
      "framer_motion_spec": {
        "initial": { "scale": 1, "opacity": 1, "x": 0, "y": 0 },
        "animate": { "scale": 0.2, "opacity": 0, "x": 150, "y": -300 },
        "transition": { "duration": 0.6, "ease": "easeInOut" }
      }
    },
    "cart_foodie_icon": {
      "description": "Cart icon bounces slightly when an item is added.",
      "framer_motion_spec": {
        "animate": { "y": [0, -10, 0] },
        "transition": { "duration": 0.3 }
      }
    },
    "marquee": {
      "description": "Continuous auto-scroll from right to left for reviews.",
      "library": "framer-motion or react-fast-marquee"
    },
    "page_transition": {
      "initial": { "opacity": 0, "x": 20 },
      "animate": { "opacity": 1, "x": 0 },
      "exit": { "opacity": 0, "x": -20 }
    }
  },
  "icons": {
    "library": "lucide-react",
    "usage": {
      "menu": "Menu",
      "cart": "ShoppingBag",
      "home": "Home",
      "orders": "Clock",
      "profile": "User",
      "address": "MapPin",
      "offers": "Tag",
      "payment": "CreditCard",
      "help": "HelpCircle"
    }
  },
