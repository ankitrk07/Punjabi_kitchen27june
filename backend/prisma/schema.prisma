datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id            String     @id
  name          String
  icon          String
  image         String
  parentId      String?
  parent        Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: Cascade)
  subcategories Category[] @relation("CategoryParent")
  dishes        Dish[]
}

model Dish {
  id          String   @id
  name        String
  price       Float
  description String
  image       String
  veg         Boolean
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  rating      Float?
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String
  phone            String?
  gender           String            // "male" | "female"
  password         String            @default("123456")
  membershipTier   String            @default("Classic")
  loyaltyPoints    Int               @default(0)
  addresses        Address[]
  cart             Json?             // Stores the active shopping cart items array
  favorites        String[]          // Stores list of favorite dish IDs
  orders           Order[]
  reservations     Reservation[]
  cateringRequests CateringRequest[]
  supportTickets   SupportTicket[]
  notifications    Notification[]
}

model Address {
  id     String @id @default(uuid())
  label  String // "Home", "Work", etc.
  line   String // street details
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id           String   @id
  items        Json     // Stores array of CartItem details
  total        Float
  status       String   // "Placed" | "Preparing" | "Ready" | "On the Way" | "Delivered" | "Cancelled"
  refundStatus String   @default("None") // "None" | "Pending" | "Completed"
  refundAmount Float    @default(0)
  createdAt    DateTime @default(now())
  mode         String   // "Dine In" | "Takeaway" | "Delivery"
  userEmail    String?
  user         User?    @relation(fields: [userEmail], references: [email], onDelete: Cascade)
}

model Reservation {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  customerName    String
  customerPhone   String
  reservationDate String   // "YYYY-MM-DD"
  reservationSlot String   // "07:00 PM"
  guests          String   // "4 Guests"
  guestCount      Int      @default(1)
  status          String   @default("Active") // "Active" | "Cancelled"
  tableNumber     Int      @default(1)
  userEmail       String?
  user            User?    @relation(fields: [userEmail], references: [email], onDelete: Cascade)
}

model CateringRequest {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  eventType   String
  guests      Int
  date        String
  phone       String
  address     String
  package     String
  details     String?
  status      String   @default("Pending") // "Pending" | "Approved" | "Denied"
  userEmail   String?
  user        User?    @relation(fields: [userEmail], references: [email], onDelete: Cascade)
}

model SupportTicket {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  subject     String
  description String
  status      String   @default("In Progress") // "In Progress" | "Resolved"
  priority    String   @default("Medium") // "High" | "Medium" | "Low"
  lastUpdate  String?
  userEmail   String
  user        User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  title     String
  message   String
  type      String   @default("Announcement") // "Announcement" | "Offer" | "OrderUpdate"
  userEmail String?  // null means sent to everyone
  user      User?    @relation(fields: [userEmail], references: [email], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  name      String
  avatar    String
  rating    Int
  text      String
  createdAt DateTime @default(now())
}
