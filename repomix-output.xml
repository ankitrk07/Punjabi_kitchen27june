import React, { useEffect, useRef } from "react";
import { View, Text, StyleSheet, Animated } from "react-native";
import { Ionicons } from "@expo/vector-icons";
import ScreenHeader from "@/src/components/ScreenHeader";
import { useApp } from "@/src/context/AppContext";
import { colors } from "@/src/theme";

const STEPS = [
  { key: "Placed", label: "Order Placed", icon: "checkmark-circle" },
  { key: "Preparing", label: "Preparing", icon: "restaurant" },
  { key: "Out for delivery", label: "Out for Delivery", icon: "bicycle" },
  { key: "Delivered", label: "Delivered", icon: "home" },
];

export default function TrackOrder() {
  const { orders } = useApp();
  const active = orders.find((o) => o.status !== "Delivered") || orders[0];
  const pulse = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.loop(
      Animated.sequence([
        Animated.timing(pulse, { toValue: 1, duration: 800, useNativeDriver: true }),
        Animated.timing(pulse, { toValue: 0, duration: 800, useNativeDriver: true }),
      ])
    ).start();
  }, []);

  const activeIdx = active ? STEPS.findIndex((s) => s.key === active.status) : -1;
  const pulseScale = pulse.interpolate({ inputRange: [0, 1], outputRange: [1, 1.4] });

  if (!active) {
    return (
      <ScreenHeader title="Track Order">
        <View style={styles.empty}>
          <Ionicons name="receipt-outline" size={56} color={colors.textSecondary} />
          <Text style={styles.emptyText}>No active orders</Text>
        </View>
      </ScreenHeader>
    );
  }

  const eta = new Date(active.createdAt + 35 * 60 * 1000);

  return (
    <ScreenHeader title="Track Order">
      <View style={styles.card}>
        <Text style={styles.id}>{active.id}</Text>
        <Text style={styles.mode}>{active.mode}</Text>
        <View style={styles.etaRow}>
          <Ionicons name="time" size={16} color={colors.gold} />
          <Text style={styles.eta}>ETA: {eta.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}</Text>
        </View>
      </View>

      <View style={styles.timeline}>
        {STEPS.map((s, idx) => {
          const isActive = idx === activeIdx;
          const done = idx <= activeIdx;
          return (
            <View key={s.key} style={styles.step}>
              <View style={styles.dotCol}>
                {isActive && (
                  <Animated.View style={[styles.pulse, { transform: [{ scale: pulseScale }] }]} />
                )}
                <View style={[styles.dot, done && styles.dotActive]}>
                  <Ionicons name={s.icon as any} size={14} color={done ? "#000" : colors.textSecondary} />
                </View>
                {idx < STEPS.length - 1 && <View style={[styles.line, done && styles.lineActive]} />}
              </View>
              <View style={styles.stepContent}>
                <Text style={[styles.stepLabel, done && { color: "#FFF" }]}>{s.label}</Text>
                {isActive && <Text style={styles.stepNote}>In progress...</Text>}
                {done && idx < activeIdx && <Text style={styles.stepNote}>Completed</Text>}
              </View>
            </View>
          );
        })}
      </View>

      <View style={styles.items}>
        <Text style={styles.itemsTitle}>Order Items</Text>
        {active.items.map((it) => (
          <View key={it.id} style={styles.itemRow}>
            <Text style={styles.itemName}>{it.name} × {it.qty}</Text>
            <Text style={styles.itemPrice}>₹{it.price * it.qty}</Text>
          </View>
        ))}
        <View style={[styles.itemRow, { borderTopWidth: 1, borderTopColor: colors.border, paddingTop: 10, marginTop: 6 }]}>
          <Text style={styles.totalLabel}>Total</Text>
          <Text style={styles.totalVal}>₹{active.total}</Text>
        </View>
      </View>
    </ScreenHeader>
  );
}

const styles = StyleSheet.create({
  empty: { alignItems: "center", paddingVertical: 60, gap: 8 },
  emptyText: { color: colors.textSecondary },
  card: { padding: 18, borderRadius: 16, backgroundColor: colors.surface, borderWidth: 1, borderColor: colors.gold, marginBottom: 20 },
  id: { color: "#FFF", fontWeight: "700", fontSize: 16 },
  mode: { color: colors.gold, fontSize: 12, marginTop: 4 },
  etaRow: { flexDirection: "row", alignItems: "center", gap: 6, marginTop: 10 },
  eta: { color: colors.gold, fontWeight: "700" },
  timeline: { paddingLeft: 4, marginBottom: 24 },
  step: { flexDirection: "row", gap: 14, minHeight: 70 },
  dotCol: { alignItems: "center", width: 30 },
  dot: { width: 30, height: 30, borderRadius: 15, backgroundColor: colors.surface, borderWidth: 2, borderColor: colors.border, alignItems: "center", justifyContent: "center" },
  dotActive: { backgroundColor: colors.gold, borderColor: colors.gold },
  pulse: { position: "absolute", width: 40, height: 40, borderRadius: 20, backgroundColor: "rgba(212,175,55,0.3)" },
  line: { width: 2, flex: 1, backgroundColor: colors.border, marginTop: 2 },
  lineActive: { backgroundColor: colors.gold },
  stepContent: { flex: 1, paddingTop: 4 },
  stepLabel: { color: colors.textSecondary, fontWeight: "600" },
  stepNote: { color: colors.gold, fontSize: 11, marginTop: 2 },
  items: { padding: 14, borderRadius: 14, backgroundColor: colors.surface, borderWidth: 1, borderColor: colors.border },
  itemsTitle: { color: colors.gold, fontWeight: "700", marginBottom: 10 },
  itemRow: { flexDirection: "row", justifyContent: "space-between", paddingVertical: 4 },
  itemName: { color: colors.textPrimary, fontSize: 13 },
  itemPrice: { color: "#FFF" },
  totalLabel: { color: "#FFF", fontWeight: "700" },
  totalVal: { color: colors.gold, fontWeight: "800", fontSize: 18 },
});
