import React from "react";
import { Animated, StyleSheet, Text, TouchableOpacity, View } from "react-native";
import { LinearGradient } from 'expo-linear-gradient';

type TopBarProps = {
  variant?: "full" | "minimal";
};

export default function TopBar({ variant = "full" }: TopBarProps) {
  const { cart, cartBumpAnim, selectedAddress } = useApp();
  const router = useRouter();

  if (variant === "minimal") {
    return <View style={styles.minimalBar} />;
  }

  const count = cart.reduce((s, i) => s + i.qty, 0);
  const cartScale = cartBumpAnim.interpolate({ inputRange: [0, 1], outputRange: [1, 1.35] });

  const openLocations = () => {
    router.push("/profile/addresses");
  };

  const onCartPress = () => {
    Animated.sequence([
      Animated.timing(cartBumpAnim, { toValue: 1, duration: 200, useNativeDriver: true }),
      Animated.timing(cartBumpAnim, { toValue: 0, duration: 200, useNativeDriver: true }),
    ]).start(() => {
      router.push("/cart");
    });
  };

  return (
    <LinearGradient
      // Completely transparent background structure.
      // This creates a pure smoky black shadow gradient that bleeds beautifully into your background image.
      colors={[
        'rgba(0, 0, 0, 0.90)',  // Deep rich shadow at the absolute top edge
        'rgba(0, 0, 0, 0.65)',  // Smoothly dispersing shadow across the middle
        'rgba(0, 0, 0, 0.20)',  // Soft feathering zone
        'rgba(0, 0, 0, 0.00)'   // Fades out into pure crystal transparency at the bottom edge
      ]}
      locations={[0, 0.4, 0.75, 1]}
      style={styles.bar}
    >
      {/* LEFT: LOCATION SELECTOR */}
      <TouchableOpacity
        style={styles.locationWrap}
        onPress={openLocations}
        activeOpacity={0.85}
      >
        {/* Polished minimal location wireframe anchored in theme gold */}
        <Ionicons name="location-outline" size={25} color="#ffffff" />

        <View style={styles.locationCopy}>
          <View style={styles.titleRow}>
            <Text style={styles.locationTitle} numberOfLines={1}>
              {selectedAddress?.label || "Select location"}
            </Text>
            <Ionicons name="chevron-down" size={12} color="rgba(255, 255, 255, 0.7)" style={styles.chevron} />
          </View>

          <Text style={styles.locationSub} numberOfLines={1}>
            {selectedAddress?.line || "Tap to add address"}
          </Text>
        </View>
      </TouchableOpacity>

      {/* RIGHT: PREMIUM CART ACCESSORY */}
      <TouchableOpacity style={styles.heartBtn} onPress={onCartPress}>
        <Ionicons name="bag-handle-outline" size={22} color="#D4AF37" />
      </TouchableOpacity>
