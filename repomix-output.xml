  const { orders } = useApp();
  const active = orders.find((o) => o.status !== "Delivered");
  if (!active) return null;
  return (
    <TouchableOpacity style={styles.orderSummary} activeOpacity={0.9}>
      <Ionicons name="bicycle" size={14} color={colors.gold} style={{ marginRight: 8 }} />
      <View>
