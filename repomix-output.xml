import DailyOffersCarousel from "@/src/components/DailyOffersCarousel";
import TopBar from "@/src/components/TopBar";
import { useApp } from "@/src/context/AppContext";
import { DISHES } from "@/src/data/menu";
import { colors } from "@/src/theme";
import { storage } from "@/src/utils/storage";
import { Ionicons } from "@expo/vector-icons";
import { useRouter } from "expo-router";
import React, { useEffect, useRef } from "react";
import {
    Alert,
    Animated,
    Dimensions,
    Image,
    Modal,
    Platform,
    ScrollView,
    StyleSheet,
    Text,
    TouchableOpacity,
    View,
} from "react-native";
import { SafeAreaView } from "react-native-safe-area-context";

const { width } = Dimensions.get("window");

// Sample offers for the carousel (replace with API data as needed)
const SAMPLE_OFFERS = [
  {
    id: "offer-1",
    title: "Butter Chicken Feast",
    subtitle: "25% off + complimentary naan",
    price: 499,
    image: "https://images.unsplash.com/photo-1604908177226-5c7b6a3a1b7b?q=80&w=1200&auto=format&fit=crop&ixlib=rb-4.0.3&s=abcd",
    badge: "HOT",
  },
  {
    id: "offer-2",
    title: "Green Garden Bowl",
    subtitle: "Buy 1 Get 1 (Veg Special)",
    price: 299,
    image: "https://images.unsplash.com/photo-1543352634-6f3d6f8b8b2c?q=80&w=1200&auto=format&fit=crop&ixlib=rb-4.0.3&s=efgh",
    badge: "VEG",
  },
  {
    id: "offer-3",
    title: "Decadent Chocolate Lava",
    subtitle: "Free scoop on orders above ₹399",
    price: 149,
    image: "https://images.unsplash.com/photo-1551024709-8f23befc6f87?q=80&w=1200&auto=format&fit=crop&ixlib=rb-4.0.3&s=ijkl",
    badge: "DESSERT",
  },
];

// ─── Design tokens ────────────────────────────────────────────────────────────
const GOLD    = "#C9A84C";
const GOLD_DIM= "rgba(201,168,76,0.13)";
const DARK_BG = "#080808";
const SURFACE = "#111111";
const MUTED   = "#555555";
const GREEN   = "#4CD97B";
const WHITE   = "#FFFFFF";

// ─── Status config ────────────────────────────────────────────────────────────
type StatusKey = "Delivered" | "On the Way" | "Preparing" | "Ready" | string;

const STATUS_CONFIG: Record<StatusKey, { color: string; bg: string; icon: string }> = {
  "Delivered":  { color: GREEN,         bg: "rgba(76,217,123,0.14)",  icon: "checkmark-circle-outline" },
  "On the Way": { color: GOLD,          bg: "rgba(201,168,76,0.14)",  icon: "bicycle-outline"          },
  "Preparing":  { color: "#FF9F43",     bg: "rgba(255,159,67,0.14)",  icon: "flame-outline"            },
  "Ready":      { color: "#54A0FF",     bg: "rgba(84,160,255,0.14)",  icon: "bag-check-outline"        },
};
const getStatus = (s: string) =>
  STATUS_CONFIG[s] ?? { color: MUTED, bg: "rgba(255,255,255,0.06)", icon: "ellipse-outline" };

// ─── Live order progress steps ────────────────────────────────────────────────
const STEPS = ["Placed", "Preparing", "Ready", "On the Way", "Delivered"];
function stepIndex(status: string) {
  const idx = STEPS.indexOf(status);
  return idx === -1 ? 1 : idx;
}

function LiveOrderCard({ order, onPress }: { order: any; onPress: () => void }) {
  const pulseAnim = useRef(new Animated.Value(1)).current;
  const fadeAnim  = useRef(new Animated.Value(0)).current;
  const slideAnim = useRef(new Animated.Value(-20)).current;
  const pressAnim = useRef(new Animated.Value(1)).current;

  const currentStep = stepIndex(order.status);

  useEffect(() => {
    Animated.parallel([
      Animated.timing(fadeAnim,  { toValue: 1, duration: 500, useNativeDriver: true }),
      Animated.timing(slideAnim, { toValue: 0, duration: 500, useNativeDriver: true }),
    ]).start();

    const pulse = Animated.loop(
      Animated.sequence([
        Animated.timing(pulseAnim, { toValue: 1.6, duration: 800, useNativeDriver: true }),
        Animated.timing(pulseAnim, { toValue: 1.0, duration: 800, useNativeDriver: true }),
      ])
    );
    pulse.start();
    return () => pulse.stop();
  }, []);

  const onIn  = () => Animated.spring(pressAnim, { toValue: 0.97, useNativeDriver: true, speed: 60 }).start();
  const onOut = () => Animated.spring(pressAnim, { toValue: 1,    useNativeDriver: true, speed: 60 }).start();

  return (
    <Animated.View
      style={{
        opacity: fadeAnim,
        transform: [{ translateY: slideAnim }, { scale: pressAnim }],
        marginBottom: 24,
      }}
    >
      <TouchableOpacity
        style={styles.liveCard}
        onPress={onPress}
        onPressIn={onIn}
        onPressOut={onOut}
        activeOpacity={1}
        testID="active-order-card"
      >
        {/* Corner brackets */}
        <View style={[styles.bracket, styles.bTL]} />
        <View style={[styles.bracket, styles.bTR]} />
        <View style={[styles.bracket, styles.bBL]} />
        <View style={[styles.bracket, styles.bBR]} />

        {/* Glow blob */}
        <View style={styles.liveGlow} />

        {/* Header */}
        <View style={styles.liveHead}>
          <View style={styles.livePillWrap}>
            <Animated.View style={[styles.livePulseDot, { transform: [{ scale: pulseAnim }] }]} />
            <View style={styles.liveDotInner} />
            <Text style={styles.liveLabel}>LIVE ORDER</Text>
          </View>
          <Text style={styles.liveId}>#{String(order.id).slice(-6).toUpperCase()}</Text>
        </View>

        {/* Progress track */}
        <View style={styles.progressWrap}>
          {STEPS.map((step, i) => {
            const done    = i <= currentStep;
            const current = i === currentStep;
            return (
              <React.Fragment key={step}>
                <View style={styles.stepCol}>
                  <View style={[
                    styles.stepDot,
                    done    && styles.stepDotDone,
                    current && styles.stepDotCurrent,
                  ]}>
                    {done && !current && (
                      <Ionicons name="checkmark" size={8} color={DARK_BG} />
                    )}
                    {current && <View style={styles.stepDotInner} />}
                  </View>
                  <Text style={[styles.stepLabel, done && styles.stepLabelDone]}>
                    {step}
                  </Text>
                </View>
                {i < STEPS.length - 1 && (
                  <View style={[styles.stepLine, i < currentStep && styles.stepLineDone]} />
                )}
              </React.Fragment>
            );
          })}
        </View>

        {/* Status + total */}
        <View style={styles.liveInfo}>
          <View>
            <Text style={styles.liveStatusLabel}>Status</Text>
            <Text style={[styles.liveStatus, { color: getStatus(order.status).color }]}>
              {order.status}
            </Text>
          </View>
          <View style={styles.liveTotalCol}>
            <Text style={styles.liveTotalLabel}>Total</Text>
            <Text style={styles.liveTotal}>₹{order.total}</Text>
          </View>
        </View>

        {/* Track button */}
        <View style={styles.trackBtnRow}>
          <View style={styles.trackShine} />
          <Ionicons name="navigate-outline" size={14} color={DARK_BG} style={{ marginRight: 8 }} />
          <Text style={styles.trackBtnText}>Track Order</Text>
          <Ionicons name="arrow-forward" size={13} color={DARK_BG} style={{ marginLeft: 6 }} />
        </View>
      </TouchableOpacity>
    </Animated.View>
  );
}

// ─── History card ─────────────────────────────────────────────────────────────
function OrderCard({ order, index, onCancel }: { order: any; index: number; onCancel?: (id: string) => void }) {
  const { processRefund } = useApp();
  const anim  = useRef(new Animated.Value(0)).current;
  const press = useRef(new Animated.Value(1)).current;
  const cfg   = getStatus(order.status);

  useEffect(() => {
    Animated.spring(anim, {
      toValue: 1, friction: 8, tension: 55,
      delay: index * 70, useNativeDriver: true,
    }).start();
  }, []);

  const onIn  = () => Animated.spring(press, { toValue: 0.97, useNativeDriver: true, speed: 60 }).start();
  const onOut = () => Animated.spring(press, { toValue: 1,    useNativeDriver: true, speed: 60 }).start();

  const dateObj  = new Date(order.createdAt);
  const dateFmt  = dateObj.toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" });
  const timeFmt  = dateObj.toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" });
  const refCode  = `#${String(order.id).slice(-6).toUpperCase()}`;

  return (
    <Animated.View
      style={{
        opacity: anim,
        transform: [
          { translateY: anim.interpolate({ inputRange: [0,1], outputRange: [24,0] }) },
          { scale: press },
        ],
        marginBottom: 10,
      }}
    >
      <TouchableOpacity
        style={styles.orderCard}
        onPressIn={onIn}
        onPressOut={onOut}
        activeOpacity={1}
        testID={`order-${order.id}`}
      >
        {/* Gold left bar */}
        <View style={[styles.orderBar, { backgroundColor: cfg.color }]} />

        <View style={styles.orderContent}>
          {/* Head row */}
          <View style={styles.orderHead}>
            <View style={styles.orderIconWrap}>
              <Ionicons name={cfg.icon as any} size={14} color={cfg.color} />
            </View>
            <Text style={styles.orderRef}>{refCode}</Text>
            <View style={[styles.orderStatusPill, { backgroundColor: cfg.bg, borderColor: `${cfg.color}30` }]}>
              <Text style={[styles.orderStatusText, { color: cfg.color }]}>{order.status}</Text>
            </View>
          </View>

          {/* Meta row */}
          <View style={styles.metaRow}>
            <Ionicons name="time-outline" size={11} color={MUTED} />
            <Text style={styles.metaText}>{dateFmt} · {timeFmt}</Text>
            <View style={styles.modePill}>
              <Text style={styles.modeText}>{order.mode}</Text>
            </View>
          </View>

          {/* Item list */}
          <View style={styles.itemsBlock}>
            {order.items.slice(0, 3).map((it: any) => (
              <View key={it.id} style={styles.itemRow}>
                <View style={styles.itemDot} />
                <Text style={styles.itemName} numberOfLines={1}>{it.name}</Text>
                <Text style={styles.itemQty}>×{it.qty}</Text>
              </View>
            ))}
            {order.items.length > 3 && (
              <Text style={styles.itemMore}>+{order.items.length - 3} more items</Text>
            )}
          </View>

          {/* Footer */}
          <View style={styles.orderFooter}>
            <View>
              <Text style={styles.orderTotalLabel}>ORDER TOTAL</Text>
              <Text style={styles.orderTotal}>₹{order.total}</Text>
            </View>
            {(() => {
              // If order cancelled, show refund status / action
              if (order.status === "Cancelled") {
                const refund = order.refund ?? { status: "None", amount: 0 };
                if (refund.status === "Pending") {
                  return (
                    <TouchableOpacity
                      style={styles.orderCancelBtn}
                      onPress={() => {
                        Alert.alert("Mark refunded", "Mark this order as refunded?", [
                          { text: "No", style: "cancel" },
                          { text: "Yes", onPress: () => processRefund(order.id) },
                        ]);
                      }}
                      testID={`refund-${order.id}`}
                    >
                      <Text style={styles.orderCancelText}>Mark Refunded</Text>
                    </TouchableOpacity>
                  );
                }
                if (refund.status === "Completed") {
                  return (
                    <View style={styles.refundedPill}>
                      <Text style={styles.refundedText}>Refunded ₹{refund.amount}</Text>
                    </View>
                  );
                }
                return null;
              }

              const cancellable = stepIndex(order.status) < 3 && order.status !== "Delivered";
              if (!cancellable || !onCancel) return null;
              return (
                <TouchableOpacity
                  style={styles.orderCancelBtn}
                  onPress={() => {
                    Alert.alert("Cancel order", "Are you sure you want to cancel this order?", [
                      { text: "No", style: "cancel" },
                      { text: "Yes", onPress: () => onCancel(order.id) },
                    ]);
                  }}
                  testID={`cancel-${order.id}`}
                >
                  <Text style={styles.orderCancelText}>Cancel</Text>
                </TouchableOpacity>
              );
            })()}
          </View>
        </View>
      </TouchableOpacity>
    </Animated.View>
  );
}

// ─── Empty state ──────────────────────────────────────────────────────────────
function EmptyState({ onPress }: { onPress: () => void }) {
  const fadeAnim  = useRef(new Animated.Value(0)).current;
  const floatAnim = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.timing(fadeAnim, { toValue: 1, duration: 600, delay: 200, useNativeDriver: true }).start();
    const float = Animated.loop(
      Animated.sequence([
        Animated.timing(floatAnim, { toValue: -8, duration: 1800, useNativeDriver: true }),
        Animated.timing(floatAnim, { toValue:  0, duration: 1800, useNativeDriver: true }),
      ])
    );
    float.start();
    return () => float.stop();
  }, []);

  return (
    <Animated.View style={[styles.emptyWrap, { opacity: fadeAnim }]}>
      <Animated.View style={[styles.emptyIconWrap, { transform: [{ translateY: floatAnim }] }]}>
        <View style={styles.emptyRingOuter} />
        <View style={styles.emptyRingInner} />
        <View style={styles.emptyIconCenter}>
          <Ionicons name="receipt-outline" size={38} color={GOLD} />
        </View>
      </Animated.View>

      <Text style={styles.emptyHeading}>No Orders Yet</Text>
      <Text style={styles.emptySub}>Your culinary journey starts here.{"\n"}Explore our menu and place your first order.</Text>

      <TouchableOpacity style={styles.ctaBtn} onPress={onPress} testID="browse-menu-btn" activeOpacity={0.85}>
        <View style={styles.ctaShine} />
        <Ionicons name="restaurant-outline" size={15} color={DARK_BG} style={{ marginRight: 8 }} />
        <Text style={styles.ctaText}>Browse Menu</Text>
      </TouchableOpacity>

      <View style={styles.emptyFooterRow}>
        <View style={styles.emptyLine} />
        <Text style={styles.emptyFooterLabel}>FAST · FRESH · PREMIUM</Text>
        <View style={styles.emptyLine} />
      </View>
    </Animated.View>
  );
}

// ─── Main screen ──────────────────────────────────────────────────────────────
export default function Orders() {
  const {
    orders,
    addToCart,
    cancelOrder,
    addItemsToOrder,
    handleTabBarScroll,
    resetTabBarVisibility,
    setTabBarUserInteracting,
  } = useApp();
  const [favoritesIds, setFavoritesIds] = React.useState<string[]>([]);
  const [favoritesOpen, setFavoritesOpen] = React.useState(false);

  // Load favorites from storage or derive from order history
  React.useEffect(() => {
    let mounted = true;
    (async () => {
      const saved = await storage.getItem<string[]>("pk_favorites", []);
      if (mounted && saved && saved.length > 0) {
        setFavoritesIds(saved);
        return;
      }

      // derive frequently ordered dishes if no saved favorites
      const freq: Record<string, number> = {};
      orders.forEach((o) => o.items.forEach((it: any) => { freq[it.id] = (freq[it.id] || 0) + (it.qty || 1); }));
      const popular = Object.entries(freq).sort((a, b) => b[1] - a[1]).slice(0, 6).map(([id]) => id);
      if (mounted && popular.length > 0) setFavoritesIds(popular);
    })();
    return () => { mounted = false; };
  }, [orders]);

  const toggleFavorite = async (id: string) => {
    setFavoritesIds((prev) => {
      const next = prev.includes(id) ? prev.filter((p) => p !== id) : [id, ...prev];
      void storage.setItem("pk_favorites", next);
      return next;
    });
  };
  const router     = useRouter();
  const active     = orders.find((o) => o.status !== "Delivered");

  const heroFade  = useRef(new Animated.Value(0)).current;
  const heroSlide = useRef(new Animated.Value(-14)).current;
  const [modifyOrderId, setModifyOrderId] = React.useState<string | null>(null);
  const [modifyMap, setModifyMap] = React.useState<Record<string, number>>({});

  const openModify = (orderId: string) => {
    setModifyOrderId(orderId);
    setModifyMap({});
  };

  const changeModifyQty = (dishId: string, delta: number) => {
    setModifyMap((prev) => {
      const q = (prev[dishId] || 0) + delta;
      const next = { ...prev };
      if (q <= 0) delete next[dishId]; else next[dishId] = q;
      return next;
    });
  };

  const submitModify = () => {
    if (!modifyOrderId) return;
    const itemsToAdd = Object.entries(modifyMap).map(([id, qty]) => {
      const d = DISHES.find((x) => x.id === id);
      return { id, qty, name: d?.name, price: d?.price, image: d?.image };
    });
    if (itemsToAdd.length > 0) {
      addItemsToOrder(modifyOrderId, itemsToAdd as any);
    }
    setModifyOrderId(null);
    setModifyMap({});
  };
  const [ordersFilter, setOrdersFilter] = React.useState<"all"|"active"|"completed"|"cancelled">("all");

  const filteredOrders = React.useMemo(() => {
    if (ordersFilter === "all") return orders;
    if (ordersFilter === "active") return orders.filter((o) => o.status !== "Delivered" && o.status !== "Cancelled");
    if (ordersFilter === "completed") return orders.filter((o) => o.status === "Delivered");
    if (ordersFilter === "cancelled") return orders.filter((o) => o.status === "Cancelled");
    return orders;
  }, [orders, ordersFilter]);

  useEffect(() => {
    Animated.parallel([
      Animated.timing(heroFade,  { toValue: 1, duration: 500, useNativeDriver: true }),
      Animated.timing(heroSlide, { toValue: 0, duration: 500, useNativeDriver: true }),
    ]).start();
  }, []);

  useEffect(() => {
    resetTabBarVisibility();
  }, [resetTabBarVisibility]);

  return (
    <SafeAreaView style={styles.safe} edges={["top"]}>
      {/* Ambient bg */}
      <View style={styles.ambientBlob1} />
      <View style={styles.ambientBlob2} />

      <TopBar variant="minimal" />

      <ScrollView
        showsVerticalScrollIndicator={false}
        contentContainerStyle={styles.scroll}
        onScroll={(event) => handleTabBarScroll(event.nativeEvent.contentOffset.y)}
        onScrollBeginDrag={() => setTabBarUserInteracting(true)}
        onScrollEndDrag={() => setTabBarUserInteracting(false)}
        scrollEventThrottle={16}
      >

        {/* Hero heading */}
        <Animated.View style={{ opacity: heroFade, transform: [{ translateY: heroSlide }], marginBottom: 20 }}>
          <View style={styles.heroTopRow}>
            <View>
              <Text style={styles.kicker}>YOUR</Text>
              <Text style={styles.heroTitle}>Orders</Text>
            </View>
            <TouchableOpacity
              style={styles.heroFavBtn}
              activeOpacity={0.85}
              onPress={() => setFavoritesOpen(true)}
            >
              <Ionicons name="heart" size={14} color={colors.gold} />
              <Text style={styles.heroFavText}>Favorites</Text>
            </TouchableOpacity>
          </View>
          <View style={styles.underlineRow}>
            <View style={styles.ulLong} />
            <View style={styles.ulShort} />
          </View>
          {orders.length > 0 && (
            <Text style={styles.heroSub}>{orders.length} order{orders.length > 1 ? "s" : ""} in your history</Text>
          )}
        </Animated.View>

        {/* Daily offers header + carousel */}
        <View style={{ marginBottom: 12 }}>
          <View style={styles.sectionRow}>
            <Text style={styles.sectionTitle}>Daily Dish Offers</Text>
            <View style={styles.sectionPill}>
              <Text style={styles.sectionCount}>{SAMPLE_OFFERS.length}</Text>
            </View>
          </View>
          <DailyOffersCarousel offers={SAMPLE_OFFERS} />
        </View>

        {/* Favorites Popup */}
        <Modal visible={favoritesOpen} transparent animationType="fade" onRequestClose={() => setFavoritesOpen(false)}>
          <View style={styles.popupOverlay}>
            <View style={styles.popupCard}>
              <View style={styles.popupHeader}>
                <Text style={styles.popupTitle}>Your Favorites</Text>
                <TouchableOpacity onPress={() => setFavoritesOpen(false)} style={styles.popupCloseBtn}>
                  <Ionicons name="close" size={18} color="#FFF" />
                </TouchableOpacity>
              </View>

              {favoritesIds.length === 0 ? (
                <View style={styles.popupEmpty}>
                  <Ionicons name="heart-dislike-outline" size={34} color={colors.gold} />
                  <Text style={styles.popupEmptyText}>No favorites yet — heart a dish to save it.</Text>
                </View>
              ) : (
                <ScrollView showsVerticalScrollIndicator={false} contentContainerStyle={{ paddingBottom: 6 }}>
                  {favoritesIds.map((id) => {
                    const dish = DISHES.find((d) => d.id === id);
                    if (!dish) return null;
                    return (
                      <View key={dish.id} style={styles.popupItem} testID={`fav-${dish.id}`}>
                        <Image source={{ uri: dish.image }} style={styles.popupItemImg} />
                        <View style={{ flex: 1, marginLeft: 12 }}>
                          <Text style={styles.popupItemTitle} numberOfLines={1}>{dish.name}</Text>
                          <Text style={styles.popupItemPrice}>₹{dish.price}</Text>
                        </View>
                        <View style={{ flexDirection: "row", alignItems: "center", gap: 8 }}>
                          <TouchableOpacity
                            onPress={() => toggleFavorite(dish.id)}
                            style={styles.popupHeartBtn}
                          >
                            <Ionicons name="heart" size={18} color={colors.gold} />
                          </TouchableOpacity>
                          <TouchableOpacity style={styles.popupAddBtn} onPress={() => addToCart(dish)} testID={`fav-add-${dish.id}`}>
                            <Ionicons name="add" size={16} color="#0A0A0A" />
                          </TouchableOpacity>
                        </View>
                      </View>
                    );
                  })}
                </ScrollView>
              )}
            </View>
          </View>
        </Modal>

        {/* Modify Order Modal */}
        <Modal visible={!!modifyOrderId} transparent animationType="slide">
          <View style={styles.modalOverlayLite}>
            <View style={styles.modalCardLite}>
              <Text style={styles.modalTitle}>Add items to order</Text>
              <ScrollView style={{ maxHeight: 320 }}>
                {DISHES.map((d) => (
                  <View key={d.id} style={styles.modifyRow}>
                    <Image source={{ uri: d.image }} style={styles.modifyImg} />
                    <View style={{ flex: 1, marginLeft: 10 }}>
                      <Text style={{ color: "#FFF", fontWeight: "800" }}>{d.name}</Text>
                      <Text style={{ color: colors.textSecondary, fontSize: 12 }}>₹{d.price}</Text>
                    </View>
                    <View style={{ flexDirection: "row", alignItems: "center", gap: 8 }}>
                      <TouchableOpacity onPress={() => changeModifyQty(d.id, -1)} style={styles.qBtn}><Ionicons name="remove" size={14} color={colors.gold} /></TouchableOpacity>
                      <Text style={{ color: "#FFF" }}>{modifyMap[d.id] || 0}</Text>
                      <TouchableOpacity onPress={() => changeModifyQty(d.id, 1)} style={styles.qBtn}><Ionicons name="add" size={14} color={colors.gold} /></TouchableOpacity>
                    </View>
                  </View>
                ))}
              </ScrollView>
              <View style={{ flexDirection: "row", gap: 8, marginTop: 12 }}>
                <TouchableOpacity style={[styles.modalBtn, { flex: 1 }]} onPress={submitModify}><Text style={styles.modalBtnText}>Add Items</Text></TouchableOpacity>
                <TouchableOpacity style={[styles.modalBtn, { backgroundColor: "#333", borderColor: colors.border }]} onPress={() => setModifyOrderId(null)}><Text style={styles.modalBtnText}>Close</Text></TouchableOpacity>
              </View>
            </View>
          </View>
        </Modal>

        {/* Live order */}
        {active && (
          <>
            <LiveOrderCard order={active} onPress={() => router.push("/orders/track")} />
            <View style={{ flexDirection: "row", gap: 8, marginBottom: 12 }}>
