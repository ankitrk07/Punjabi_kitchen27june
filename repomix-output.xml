import { useApp } from "@/src/context/AppContext";
import { Ionicons } from "@expo/vector-icons";
import { useRouter } from "expo-router";
import React, { useEffect, useRef } from "react";
import {
    Animated,
    Dimensions,
    Image,
    Platform,
    ScrollView,
    StyleSheet,
    Text,
    TouchableOpacity,
    View,
} from "react-native";
import { SafeAreaView } from "react-native-safe-area-context";

const { width } = Dimensions.get("window");

// ─── Design tokens ────────────────────────────────────────────────────────────
const GOLD       = "#C9A84C";
const GOLD_LIGHT = "#F0D488";
const GOLD_DIM   = "#C9A84C28";
const DARK_BG    = "#080808";
const SURFACE    = "#111111";
const SURFACE_2  = "#181818";
const RED        = "#E85555";
const WHITE      = "#FFFFFF";
const MUTED      = "#555555";
const MUTED_2    = "#333333";

const menuItems = [
  { key: "orders",    label: "My Orders",         icon: "receipt-outline",       route: "/orders/history",     sub: "View your history"    },
  { key: "track",     label: "Track Order",        icon: "navigate-circle-outline",route: "/orders/track",      sub: "Live GPS tracking"    },
  { key: "addresses", label: "Saved Addresses",    icon: "home-outline",          route: "/profile/addresses",  sub: "Manage locations"     },
  { key: "edit",      label: "Edit Profile",       icon: "person-outline",        route: "/profile/edit",       sub: "Update your details"  },
  { key: "offers",    label: "Offers & Coupons",   icon: "pricetags-outline",     route: "/profile/offers",     sub: "Exclusive savings"    },
  { key: "payments",  label: "Payments",           icon: "card-outline",          route: "/profile/payments",   sub: "Cards & wallets"      },
  { key: "help",      label: "Help & Support",     icon: "help-circle-outline",   route: "/profile/help",       sub: "We're here for you"   },
];

// ─── Animated Menu Row ────────────────────────────────────────────────────────
function MenuItem({
  item,
  index,
  onPress,
}: {
  item: (typeof menuItems)[0];
  index: number;
  onPress: (r: string) => void;
}) {
  const slideAnim = useRef(new Animated.Value(0)).current;
  const pressAnim = useRef(new Animated.Value(1)).current;

  useEffect(() => {
    Animated.timing(slideAnim, {
      toValue: 1,
      duration: 450,
      delay: 350 + index * 65,
      useNativeDriver: true,
    }).start();
  }, []);

  const handlePressIn = () =>
    Animated.spring(pressAnim, { toValue: 0.965, useNativeDriver: true, speed: 60 }).start();
  const handlePressOut = () =>
    Animated.spring(pressAnim, { toValue: 1, useNativeDriver: true, speed: 60 }).start();

  return (
    <Animated.View
      style={{
        opacity: slideAnim,
        transform: [
          {
            translateX: slideAnim.interpolate({
              inputRange: [0, 1],
              outputRange: [48, 0],
            }),
          },
          { scale: pressAnim },
        ],
      }}
    >
      <TouchableOpacity
        style={styles.menuItem}
        onPress={() => onPress(item.route)}
        onPressIn={handlePressIn}
        onPressOut={handlePressOut}
        testID={`profile-${item.key}`}
        activeOpacity={1}
      >
        {/* Gold left bar */}
        <View style={styles.menuBar} />

        {/* Icon bubble */}
        <View style={styles.menuIconBubble}>
          <Ionicons name={item.icon as any} size={17} color={GOLD} />
        </View>

        {/* Labels */}
        <View style={styles.menuTextCol}>
          <Text style={styles.menuLabel}>{item.label}</Text>
          <Text style={styles.menuSub}>{item.sub}</Text>
        </View>

        {/* Chevron */}
        <View style={styles.menuChevron}>
          <Ionicons name="chevron-forward" size={13} color={GOLD} />
        </View>
      </TouchableOpacity>
    </Animated.View>
  );
}

// ─── Main Screen ──────────────────────────────────────────────────────────────
export default function Profile() {
  const router = useRouter();
  const {
    user,
    signOut,
    handleTabBarScroll,
    resetTabBarVisibility,
    setTabBarUserInteracting,
  } = useApp();

  // Animations
  const headerFade  = useRef(new Animated.Value(0)).current;
  const cardFade    = useRef(new Animated.Value(0)).current;
  const cardSlide   = useRef(new Animated.Value(30)).current;
  const avatarScale = useRef(new Animated.Value(0.6)).current;
  const pulseOuter  = useRef(new Animated.Value(1)).current;
  const pulseInner  = useRef(new Animated.Value(1)).current;
  const badgeFade   = useRef(new Animated.Value(0)).current;
  const goldLineW   = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    // Header fade
    Animated.timing(headerFade, { toValue: 1, duration: 500, useNativeDriver: true }).start();

    // Hero card slide-up
    Animated.parallel([
      Animated.timing(cardFade,  { toValue: 1, duration: 600, delay: 80,  useNativeDriver: true }),
      Animated.timing(cardSlide, { toValue: 0, duration: 600, delay: 80,  useNativeDriver: true }),
    ]).start();

    // Avatar pop
    Animated.spring(avatarScale, { toValue: 1, friction: 5, tension: 90, delay: 250, useNativeDriver: true }).start();

    // Gold line reveal
    Animated.timing(goldLineW, { toValue: 1, duration: 800, delay: 500, useNativeDriver: false }).start();

    // Badge fade
    Animated.timing(badgeFade, { toValue: 1, duration: 400, delay: 700, useNativeDriver: true }).start();

    // Pulse outer ring
    const pulse = Animated.loop(
      Animated.sequence([
        Animated.timing(pulseOuter, { toValue: 1.14, duration: 1400, useNativeDriver: true }),
        Animated.timing(pulseOuter, { toValue: 1.00, duration: 1400, useNativeDriver: true }),
      ])
    );
    const pulse2 = Animated.loop(
      Animated.sequence([
        Animated.timing(pulseInner, { toValue: 1.07, duration: 1400, delay: 300, useNativeDriver: true }),
        Animated.timing(pulseInner, { toValue: 1.00, duration: 1400, useNativeDriver: true }),
      ])
    );
    pulse.start();
    pulse2.start();
    return () => { pulse.stop(); pulse2.stop(); };
